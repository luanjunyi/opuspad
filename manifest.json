{
  "manifest_version": 3,
  "name": "OpusPad",
  "version": "1.1",
  "description": "Review and edit local Markdown files in Chrome. WYSIWYG + source mode. 100% private, zero uploads. Built for AI-indigenous builders.",
  "action": {
    "default_title": "Open Editor",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": []
}
